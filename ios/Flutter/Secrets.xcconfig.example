// Template for the gitignored Secrets.xcconfig.
//
// Copy this file to `Secrets.xcconfig` (same folder) and set your Google Maps
// SDK for iOS key. The real Secrets.xcconfig is gitignored and never committed.
//
//   cp Secrets.xcconfig.example Secrets.xcconfig
//   # then edit the line below
//
// The value is exposed to Info.plist as $(MAPS_API_KEY) and read in
// AppDelegate.swift. Separate from GOOGLE_PLACES_API_KEY.
MAPS_API_KEY=
